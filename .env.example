# Helius RPC — optional, significantly improves rate limits on Solana RPC calls
HELIUS_API_KEY=

# Solana RPC endpoint — defaults to public mainnet if not set
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Server port
PORT=8000

# Log verbosity
LOG_LEVEL=info

# LLM providers — both optional; cascade tries Anthropic first, then Groq,
# then falls back to deterministic templates.
ANTHROPIC_API_KEY=sk-ant-...   # primary — console.anthropic.com
GROQ_API_KEY=gsk_...           # fallback — free tier at console.groq.com

# Tokenization / buyback (fill in after token launch)
AGENT_WALLET_PRIVATE_KEY=      # DO NOT COMMIT — Base wallet key
SPROBE_TOKEN_ADDRESS=          # Fill in after token launch
BUYBACK_INTERVAL_MINUTES=60
BUYBACK_THRESHOLD_USDC=5.0
DRY_RUN=true                   # Set to false after token is live
